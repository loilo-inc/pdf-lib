{
  "name": "@loilo-inc/pdf-lib",
  "version": "1.17.1",
  "scripts": {
    "release:latest": "npm run publish --tag latest && npm run pack && npm run release:tag",
    "release:next": "npm run publish --tag next",
    "release:prep": "npm run clean && npm run lint && npm run typecheck && npm run test && npm run build",
    "release:tag": "TAG=\"v$(npm run --silent get:version)\" && git tag $TAG && git push origin $TAG",
    "get:version": "node --eval 'console.log(require(`./package.json`).version)'",
    "typecheck": "tsc --noEmit --incremental false --tsBuildInfoFile null",
    "test": "vitest run --config vitest.config.ts",
    "testw": "vitest --config vitest.config.ts",
    "testc": "vitest run --config vitest.config.ts --coverage && open coverage/index.html",
    "build": "npm run build:esm && npm run build:esm:min && npm run build:umd && npm run build:umd:min && npm run build:downlevel-dts",
    "build:esm": "rollup --config rollup.config.js --file dist/pdf-lib.esm.js --environment MODULE_TYPE:es",
    "build:esm:min": "rollup --config rollup.config.js --file dist/pdf-lib.esm.min.js --environment MINIFY,MODULE_TYPE:es",
    "build:downlevel-dts": "rimraf ts3.4 && npm run downlevel-dts . ts3.4 && rimraf ts3.4/scratchpad",
    "scratchpad:start": "ttsc --build scratchpad/tsconfig.json --watch",
    "scratchpad:run": "node scratchpad/build/scratchpad/index.js",
    "scratchpad:flame": "rimraf isolate*.log && node --prof scratchpad/build/scratchpad/index.js && node --prof-process --preprocess -j isolate*.log | flamebearer",
    "apps:node": "ttsc --build apps/node/tsconfig.json && node apps/node-build/index.js",
    "apps:web": "http-server -c-1 .",
    "apps:web:mac": "bash -c 'sleep 1 && open http://localhost:8080/apps/web/test1.html' & npm run apps:web"
  },
  "main": "cjs/index.js",
  "module": "es/index.js",
  "unpkg": "dist/pdf-lib.min.js",
  "types": "cjs/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "package.json",
    "README.md",
    "npm run.lock"
  ],
  "dependencies": {
    "@pdf-lib/standard-fonts": "^1.0.0",
    "@pdf-lib/upng": "^1.0.1",
    "esbuild": "^0.27.3",
    "pako": "^1.0.11",
    "tslib": "^1.11.1"
  },
  "devDependencies": {
    "@pdf-lib/fontkit": "^1.1.0",
    "@types/node-fetch": "^2.5.7",
    "@types/pako": "^1.0.1",
    "downlevel-dts": "^0.5.0",
    "flamebearer": "^1.1.3",
    "http-server": "^0.12.3",
    "node-fetch": "^2.6.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "private": true
}
